# Redis connection URL
# Format: redis://default:password@host:port
# For TLS (recommended for production): rediss://default:password@host:port
# Get a free Redis instance at https://upstash.com
REDIS_URL=redis://default:yourpassword@your-host.upstash.io:6379

# Server port (default: 5000)
PORT=5000

# Worker only — URL of the backend API (used when running worker separately)
# API_URL=http://localhost:5000
