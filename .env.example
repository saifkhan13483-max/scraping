# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Redis ───────────────────────────────────────────────────────────────────
# Redis connection URL (optional — falls back to in-memory store if not set)
# Format: redis://default:password@host:port
# For TLS (recommended for production): rediss://default:password@host:port
# Get a free Redis instance at https://upstash.com
# REDIS_URL=rediss://default:password@host:port

# ─── Session ─────────────────────────────────────────────────────────────────
# Secret used to sign session cookies — change this to a random string in production!
SESSION_SECRET=change-me-to-a-random-secret-in-production

# ─── Server ──────────────────────────────────────────────────────────────────
# Server port (default: 5000)
PORT=5000

# Node environment (development | production)
NODE_ENV=development

# ─── CORS (split deployment only) ────────────────────────────────────────────
# Set this when the frontend is on a different domain (e.g. Vercel → Railway).
# Comma-separated list of allowed origins (no trailing slash).
# CORS_ORIGIN=https://your-app.vercel.app

# ─── Admin ───────────────────────────────────────────────────────────────────
# Email address that is automatically granted admin rights on first login/registration.
# OWNER_EMAIL=you@example.com

# ─── Worker (external Playwright worker only) ────────────────────────────────
# URL of the backend API — used when running the worker as a separate service.
# WORKER_API_URL=http://localhost:5000
